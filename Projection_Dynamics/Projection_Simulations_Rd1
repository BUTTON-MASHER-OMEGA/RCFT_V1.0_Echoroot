import numpy as np
import math
from collections import defaultdict
from dataclasses import dataclass

# ============================================================
# 1. CONFIGURATION
# ============================================================

@dataclass
class Config:
    lam: float
    delta: float
    beta: float
    alpha: float = 1.0
    T_tol: float = 1.0
    memory_sign: int = -1  # -1 reinforce, +1 penalize
    sat_mode: str = "tanh"
    seed: int = 1
    num_steps: int = 20000


# ============================================================
# 2. GRAPH + PROJECTION
# ============================================================

states = list(range(8))

proj_structured = {
    0: 0, 1: 0,
    2: 1, 3: 1,
    4: 2, 5: 2,
    6: 3, 7: 3,
}

neighbors = {
    0: [1, 3, 6],
    1: [0, 2],
    2: [1, 3, 4],
    3: [0, 2],
    4: [5, 7, 2],
    5: [4, 6],
    6: [5, 7, 0],
    7: [4, 6],
}


# ============================================================
# 3. MEMORY SATURATION
# ============================================================

def saturate_memory(M, mode="tanh"):
    if mode == "tanh":
        return np.tanh(M)
    elif mode == "frac":
        return M / (1.0 + M) if M > 0 else 0.0
    else:
        return M


# ============================================================
# 4. FRICTION + TRANSITION PROBABILITIES
# ============================================================

def friction(u_i, u_j, mem_weights, cfg: Config, proj_map):
    d_graph = 1.0
    delta_proj = 0.0 if proj_map[u_i] == proj_map[u_j] else 1.0
    M_raw = mem_weights[(u_i, u_j)]
    M_sat = saturate_memory(M_raw, mode=cfg.sat_mode)
    return cfg.alpha * d_graph + cfg.beta * delta_proj + cfg.memory_sign * cfg.lam * M_sat


def transition_probs(u_i, mem_weights, cfg: Config, proj_map):
    nbrs = neighbors[u_i]
    costs = np.array([
        friction(u_i, u_j, mem_weights, cfg, proj_map)
        for u_j in nbrs
    ])
    weights = np.exp(-costs / cfg.T_tol)
    probs = weights / weights.sum()
    return nbrs, probs


# ============================================================
# 5. SIMULATION ENGINE
# ============================================================

def simulate(cfg: Config, proj_map=None):
    if proj_map is None:
        proj_map = proj_structured

    rng = np.random.default_rng(cfg.seed)
    mem_weights = defaultdict(float)

    u = 0
    hidden = [u]
    obs = [proj_map[u]]
    frictions = []
    pair_counts = defaultdict(int)
    edge_counts = defaultdict(int)

    for _ in range(cfg.num_steps):
        nbrs, probs = transition_probs(u, mem_weights, cfg, proj_map)
        u_next = rng.choice(nbrs, p=probs)

        F_chosen = friction(u, u_next, mem_weights, cfg, proj_map)
        frictions.append(F_chosen)

        # exponential memory
        for key in list(mem_weights.keys()):
            mem_weights[key] *= cfg.delta
            if mem_weights[key] < 1e-12:
                del mem_weights[key]
        mem_weights[(u, u_next)] += 1.0

        pair_counts[(u, u_next)] += 1
        edge_counts[(u, u_next)] += 1

        u = u_next
        hidden.append(u)
        obs.append(proj_map[u])

    return (
        np.array(hidden),
        np.array(obs),
        np.array(frictions),
        dict(mem_weights),
        dict(pair_counts),
        dict(edge_counts),
    )


# ============================================================
# 6. ORDERING-SENSITIVITY METRICS
# ============================================================

def compute_edge_entropy(edge_counts):
    total = sum(edge_counts.values())
    if total == 0:
        return 0.0
    H = 0.0
    for c in edge_counts.values():
        p = c / total
        H -= p * math.log(p + 1e-12)
    return H


def compute_valid_fraction(hidden):
    total = len(hidden) - 1
    if total <= 0:
        return 0.0
    valid = 0
    for i in range(total):
        u, v = hidden[i], hidden[i+1]
        if v in neighbors[u]:
            valid += 1
    return valid / total


def compute_conditional_entropy(hidden):
    trans_counts = defaultdict(int)
    from_counts = defaultdict(int)

    for i in range(len(hidden) - 1):
        u, v = hidden[i], hidden[i+1]
        trans_counts[(u, v)] += 1
        from_counts[u] += 1

    H = 0.0
    total = len(hidden) - 1
    if total <= 0:
        return 0.0

    for (u, v), c in trans_counts.items():
        p_uv = c / total
        p_v_given_u = c / from_counts[u]
        H -= p_uv * math.log(p_v_given_u + 1e-12)

    return H


# ============================================================
# 7. ANALYSIS: ATTRACTORS + TEMPORAL STRUCTURE
# ============================================================

def analyze_run(hidden, edge_counts, obs, shuffle_trials=5):
    print("=== Run Analysis ===")

    uniq_states = len(set(hidden))
    uniq_edges = len([e for e, c in edge_counts.items() if c > 0])

    print(f"Unique states visited: {uniq_states}")
    print(f"Unique edges visited:  {uniq_edges}")

    print("\nTop edges:")
    top = sorted(edge_counts.items(), key=lambda x: x[1], reverse=True)[:10]
    for (i, j), c in top:
        print(f"  {i}->{j}: {c}")

    print("\nCycle length estimate:")
    tail = hidden[-500:]
    cycle_len = None
    for k in range(2, 200):
        if k * 2 <= len(tail):
            if np.all(tail[-k:] == tail[-2*k:-k]):
                cycle_len = k
                break
    if cycle_len is None:
        print("  No small cycle detected (k <= 200).")
    else:
        print(f"  Estimated cycle length: {cycle_len}")

    print("\nOrdering sensitivity (shuffle test):")

    H_edge_orig = compute_edge_entropy(edge_counts)
    valid_orig = compute_valid_fraction(hidden)
    H_cond_orig = compute_conditional_entropy(hidden)

    H_edge_shuf = []
    valid_shuf = []
    H_cond_shuf = []

    for _ in range(shuffle_trials):
        shuf = np.copy(hidden)
        np.random.shuffle(shuf)

        ec_shuf = defaultdict(int)
        for i in range(len(shuf) - 1):
            u, v = shuf[i], shuf[i+1]
            ec_shuf[(u, v)] += 1

        H_edge_shuf.append(compute_edge_entropy(ec_shuf))
        valid_shuf.append(compute_valid_fraction(shuf))
        H_cond_shuf.append(compute_conditional_entropy(shuf))

    print(f"  H_edge (orig):      {H_edge_orig:.4f}")
    print(f"  H_edge (shuf):      {np.mean(H_edge_shuf):.4f}")

    print(f"  valid frac (orig):  {valid_orig:.4f}")
    print(f"  valid frac (shuf):  {np.mean(valid_shuf):.4f}")

    print(f"  H_cond (orig):      {H_cond_orig:.4f}")
    print(f"  H_cond (shuf):      {np.mean(H_cond_shuf):.4f}")


# ============================================================
# 8. DRIVER: RUN + ANALYZE
# ============================================================

def run_and_analyze(cfg: Config):
    label = "penalize" if cfg.memory_sign == +1 else "reinforce"

    print("\n====================================")
    print("Running simulation:")
    print(f"  lambda       = {cfg.lam}")
    print(f"  delta        = {cfg.delta}")
    print(f"  memory_sign  = {cfg.memory_sign}  ({label})")
    print(f"  beta         = {cfg.beta}")
    print(f"  sat_mode     = {cfg.sat_mode}")
    print("====================================\n")

    hidden, obs, F, mem_weights, pair_counts, edge_counts = simulate(cfg, proj_map=proj_structured)

    analyze_run(
        hidden=hidden,
        edge_counts=edge_counts,
        obs=obs,
        shuffle_trials=5,
    )

    print("\nDone.\n")


# ============================================================
# 9. BETA SWEEP (PROJECTION CONTROL)
# ============================================================

def run_beta_sweep():
    betas = [0.0, 1.0, 2.0, 4.0]
    experiments = [
        (0.3, 0.90),
        (1.0, 0.95),
        (2.0, 0.98),
    ]

    for lam, delta in experiments:
        for b in betas:
            cfg = Config(
                lam=lam,
                delta=delta,
                beta=b,
                alpha=1.0,
                T_tol=1.0,
                memory_sign=-1,
                sat_mode="tanh",
                seed=1,
                num_steps=20000,
            )
            print("\n####################################")
            print(f"beta = {cfg.beta}, lambda = {cfg.lam}, delta = {cfg.delta}, sign = {cfg.memory_sign}")
            print("####################################")
            run_and_analyze(cfg)


# ============================================================
# 10. MAIN
# ============================================================

if __name__ == "__main__":
    run_beta_sweep()



