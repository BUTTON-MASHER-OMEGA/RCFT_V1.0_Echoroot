import numpy as np
from collections import defaultdict

# ============================================
# RCFT Toy Universe: δ-sweep for both signs
# ============================================

states = list(range(8))

proj_structured = {
    0: 0, 1: 0,
    2: 1, 3: 1,
    4: 2, 5: 2,
    6: 3, 7: 3,
}

neighbors = {
    0: [1, 3, 6],
    1: [0, 2],
    2: [1, 3, 4],
    3: [0, 2],
    4: [5, 7, 2],
    5: [4, 6],
    6: [5, 7, 0],
    7: [4, 6],
}

alpha = 1.0
beta  = 2.0
T_tol = 1.0


def friction(u_i, u_j, mem_weights, lam, proj_map, memory_sign):
    d_graph = 1.0
    delta_proj = 0.0 if proj_map[u_i] == proj_map[u_j] else 1.0
    M_ij = mem_weights[(u_i, u_j)]
    # memory_sign = +1 (penalize), -1 (reinforce)
    return alpha * d_graph + beta * delta_proj + memory_sign * lam * M_ij


def transition_probs(u_i, mem_weights, lam, proj_map, memory_sign):
    nbrs = neighbors[u_i]
    costs = np.array([
        friction(u_i, u_j, mem_weights, lam, proj_map, memory_sign)
        for u_j in nbrs
    ])
    weights = np.exp(-costs / T_tol)
    probs = weights / weights.sum()
    return nbrs, probs


def simulate(num_steps=20000,
             lam=1.0,
             seed=0,
             decay_rate=0.98,
             proj_map=None,
             memory_sign=+1):

    if proj_map is None:
        proj_map = proj_structured

    rng = np.random.default_rng(seed)
    mem_weights = defaultdict(float)

    u = 0
    hidden = [u]
    obs = [proj_map[u]]
    frictions = []

    pair_counts = defaultdict(int)
    edge_counts = defaultdict(int)

    for t in range(num_steps):
        nbrs, probs = transition_probs(u, mem_weights, lam, proj_map, memory_sign)
        u_next = rng.choice(nbrs, p=probs)

        F_chosen = friction(u, u_next, mem_weights, lam, proj_map, memory_sign)
        frictions.append(F_chosen)

        # exponential decay memory
        for key in list(mem_weights.keys()):
            mem_weights[key] *= decay_rate
            if mem_weights[key] < 1e-12:
                del mem_weights[key]
        mem_weights[(u, u_next)] += 1.0

        pair_counts[(u, u_next)] += 1
        edge_counts[(u, u_next)] += 1

        u = u_next
        hidden.append(u)
        obs.append(proj_map[u])

    return (
        np.array(hidden),
        np.array(obs),
        np.array(frictions),
        dict(mem_weights),
        dict(pair_counts),
        dict(edge_counts),
    )


def entropy(p):
    p = np.array(p, dtype=float)
    p = p[p > 0]
    if len(p) == 0:
        return 0.0
    return -np.sum(p * np.log(p))


def coherence_measures(hidden, obs, frictions, mem_weights, pair_counts, edge_counts):
    C_F = -frictions.mean()

    O_t = obs[:-1]
    O_tp1 = obs[1:]
    C_P = 1.0 - (O_tp1 != O_t).mean()

    weights = np.array([w for w in mem_weights.values() if w > 0], dtype=float)
    C_M = np.sum((weights / weights.sum())**2) if weights.size > 0 else 0.0

    total_pairs = sum(pair_counts.values())
    if total_pairs == 0:
        C_H = 0.0
    else:
        P_ij = {k: v / total_pairs for k, v in pair_counts.items()}
        P_i = defaultdict(float)
        for (i, j), p in P_ij.items():
            P_i[i] += p

        H_cond = 0.0
        for i in states:
            denom = P_i[i]
            if denom == 0:
                continue
            cond_probs = [(P_ij.get((i, j), 0.0) / denom) for j in states]
            H_cond += P_i[i] * entropy(cond_probs)
        C_H = -H_cond

    all_edges = sum(len(neighbors[i]) for i in states)
    used_edges = sum(1 for w in mem_weights.values() if w > 0)
    C_R = used_edges / all_edges if all_edges > 0 else 0.0

    total_edge_traversals = sum(edge_counts.values())
    if total_edge_traversals == 0:
        H_edge = 0.0
    else:
        p_edges = np.array([c / total_edge_traversals for c in edge_counts.values()])
        H_edge = entropy(p_edges)

    return C_F, C_P, C_M, C_H, C_R, H_edge


