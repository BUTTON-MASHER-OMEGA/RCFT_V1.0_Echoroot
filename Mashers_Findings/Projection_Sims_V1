            print("  P(O_{t+1}|O_t=Cur,O_{t-1}=Prev):", K2_1[prev, cur])
            print()

    # Coherence curves
    C0 = coherence_curve(F0)
    C1 = coherence_curve(F1)
    print("Final C(t) no-memory:", C0[-1])
    print("Final C(t) with-memory:", C1[-1])



