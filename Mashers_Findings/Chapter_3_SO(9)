# Minkowski metric on 4D (−,+,+,+)
ETA = np.diag([-1.0, 1.0, 1.0, 1.0])

def minkowski_norm(x4):
    """Return η(x, x) for a 4-vector x."""
    return float(x4.T @ ETA @ x4)

def is_null_4d(x4, tol=1e-9):
    """Check if a 4-vector is null in Minkowski space."""
    return abs(minkowski_norm(x4)) < tol

