def random_so5_matrix():
    """Random element of SO(5) via QR."""
    M = np.random.normal(size=(5, 5))
    Q, R = np.linalg.qr(M)
    if np.linalg.det(Q) < 0:
        Q[:, 0] *= -1
    return Q

def boost_matrix(axis=1, rapidity=None):
    """
    Simple Lorentz boost in (t, x_axis) plane.
    axis: 1, 2, or 3 for x, y, z.
    rapidity: random if None.
    """
    if rapidity is None:
        rapidity = np.random.uniform(-1.0, 1.0)
    ch = np.cosh(rapidity)
    sh = np.sinh(rapidity)

    L = np.eye(4)
    # time-time and axis-axis
    L[0, 0] = ch
    L[axis, axis] = ch
    # off-diagonal
    L[0, axis] = sh
    L[axis, 0] = sh
    return L

def spatial_rotation_3d(axis1=1, axis2=2, theta=None):
    """
    Simple spatial rotation in the (axis1, axis2) plane among x,y,z.
    axis1, axis2 in {1,2,3}.
    """
    if theta is None:
        theta = np.random.uniform(0, 2*np.pi)
    R = np.eye(4)
    c, s = np.cos(theta), np.sin(theta)
    R[axis1, axis1] = c
    R[axis1, axis2] = -s
    R[axis2, axis1] = s
    R[axis2, axis2] = c
    return R

def random_so31_matrix(num_factors=3):
    """
    Build a random SO(3,1) element by composing a few boosts and rotations.
    This is not Haar-uniform, but good enough for a probe.
    """
    L = np.eye(4)
    for _ in range(num_factors):
        # random boost
        axis = np.random.choice([1, 2, 3])
        L = boost_matrix(axis=axis) @ L
        # random spatial rotation
        a1, a2 = np.random.choice([1, 2, 3], size=2, replace=False)
        L = spatial_rotation_3d(axis1=a1, axis2=a2) @ L
    return L

def is_lorentz_matrix(L4, tol=1e-6):
    """Check L^T η L ≈ η."""
    lhs = L4.T @ ETA @ L4
