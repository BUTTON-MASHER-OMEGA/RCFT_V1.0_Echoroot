def random_so9_matrix():
    """
    Generate a random element of SO(9) via QR decomposition.
    This is a generic SO(9) element, not yet restricted to G_phys.
    """
    M = np.random.normal(size=(9, 9))
    Q, R = np.linalg.qr(M)
    # Ensure det(Q) = +1
    if np.linalg.det(Q) < 0:
        Q[:, 0] *= -1
    return Q

def apply_so9(R, v9):
    """Apply a 9x9 rotation R to a 9D vector v9."""
    return R @ v9

# ================================
# 3. Lorentz projection Π_geo: R^9 → R^{3,1}
# ================================

def lorentz_projection(v9):
    """
    Simple ansatz: split R^9 = R^{3,1} ⊕ R^5.
    Interpret the first 4 components as the Lorentz sector.
    The remaining 5 are internal/bulk directions.
    """
    x4 = v9[:4]   # Lorentz sector
    y5 = v9[4:]   # internal sector
    return x4, y5

def Pi_geo(R):
    """
    Induced map on the Lorentz sector:
    - Take an SO(9) matrix R.
    - Restrict its action to the first 4 components.
    - Return the effective 4x4 block as a candidate SO(3,1) element.
    NOTE: This is a *probe*, not guaranteed to be exactly Lorentz yet.
    """
    # Act on basis vectors e_0,...,e_3 in R^9 and project
    basis9 = np.eye(9)
    images4 = []
    for i in range(4):
        v9 = basis9[:, i]
        v9p = R @ v9
        x4p, _ = lorentz_projection(v9p)
        images4.append(x4p)
    # Columns of M4 are the images of the 4D basis
    M4 = np.stack(images4, axis=1)  # shape (4,4)
    return M4

def is_lorentz_matrix(L4, tol=1e-6):
    """
    Check if a 4x4 matrix approximately preserves the Minkowski metric:
    L^T η L ≈ η
    """
    lhs = L4.T @ ETA @ L4
    return np.allclose(lhs, ETA, atol=tol)

# ================================
# 4. Null capsule test
# ================================

def so9_null_capsule(num_samples=100):
    """
    Probe:
    - Sample random SO(9) matrices.
    - For each, compute the induced 4x4 map Π_geo(R).
    - Check:
        * Does Π_geo(R) approximately preserve η?
        * Do bulk null-like directions project to 4D null directions?
    """
    results = {
        "lorentz_like_count": 0,
        "null_preserved_count": 0,
        "total": num_samples
    }

    for _ in range(num_samples):
        R = random_so9_matrix()
        L4 = Pi_geo(R)

        # Check if induced map is Lorentz-like
        lorentz_like = is_lorentz_matrix(L4)

        # Pick a random 9D vector, force its 4D part to be null
        x4 = np.random.normal(size=4)
        # Project to null by subtracting time component appropriately
        # If x is spacelike, we can force null by rescaling; here we just
        # construct a simple null vector explicitly:
        x4[0] = norm(x4[1:])  # ensure -x0^2 + |x|^2 ≈ 0
        v9 = np.concatenate([x4, np.random.normal(size=5)])

        # Apply R and project
        v9p = apply_so9(R, v9)
        x4p, _ = lorentz_projection(v9p)

        null_preserved = is_null_4d(x4p)

        if lorentz_like:
            results["lorentz_like_count"] += 1
        if null_preserved:
            results["null_preserved_count"] += 1

    return results

