import numpy as np
import random
from collections import defaultdict

# ============================================================
# RCFT Toy Universe Simulation
# Balanced Regime: α = β = 0.5, beam_width = 100, max_depth = 15
# ============================================================

# ------------------------------------------------------------
# 1. Build a synthetic "120-cell-like" graph
# ------------------------------------------------------------
# True 120-cell generation is heavy; we approximate with:
# - N = 600 vertices (same order as 600-cell)
# - Regular degree ~12 (similar to 120-cell vertex degree)
# - Random symmetric adjacency with constraints

def build_symmetric_graph(num_vertices=600, degree=12):
    adjacency = [[] for _ in range(num_vertices)]
    for v in range(num_vertices):
        while len(adjacency[v]) < degree:
            w = random.randint(0, num_vertices - 1)
            if w != v and w not in adjacency[v]:
                adjacency[v].append(w)
                adjacency[w].append(v)
    return adjacency

# ------------------------------------------------------------
# 2. Assign memory labels M(v) ∈ {-1,0,1}^3
# ------------------------------------------------------------

def assign_memory_labels(num_vertices):
    return {v: np.random.randint(-1, 2, size=3) for v in range(num_vertices)}

# ------------------------------------------------------------
# 3. Assign geometry labels G(v) = (t,x,y,z)
# ------------------------------------------------------------

def assign_geometry_labels(num_vertices):
    G = {}
    for v in range(num_vertices):
        # Random 4-vector with mild structure
        t = np.random.normal(0, 1)
        x, y, z = np.random.normal(0, 1, size=3)
        G[v] = np.array([t, x, y, z])
    return G

def minkowski_norm(Gv):
    t, x, y, z = Gv
    return -t*t + x*x + y*y + z*z

# ------------------------------------------------------------
# 4. Coherence functional
# ------------------------------------------------------------

alpha = 0.5
beta = 0.5

def step_coherence(v, w, M, G):
    # Memory coherence
    dM = np.linalg.norm(M[w] - M[v])**2
    C_M = np.exp(-alpha * dM)

    # Geometry coherence
    eta_v = minkowski_norm(G[v])
    eta_w = minkowski_norm(G[w])
    C_G = np.exp(-beta * abs(eta_w - eta_v))

    return C_M * C_G

# ------------------------------------------------------------
# 5. Buffer / Branch / Prune loop
# ------------------------------------------------------------

def run_simulation(adjacency, M, G, seed=0, max_depth=15, beam_width=100, coherence_floor=-7):
    # Each trajectory: (vertex_list, log_coherence)
    buffer = [([seed], 0.0)]

    for depth in range(max_depth):
        candidates = []

        for traj, logC in buffer:
            v = traj[-1]
            for w in adjacency[v]:
                C_step = step_coherence(v, w, M, G)
                logC_new = logC + np.log(C_step)
                candidates.append((traj + [w], logC_new))

        # Prune by coherence floor
        candidates = [(t, c) for (t, c) in candidates if c >= coherence_floor]

        if not candidates:
            print(f"Buffer emptied at depth {depth}")
            break

        # Beam pruning: keep top trajectories
        candidates.sort(key=lambda x: x[1], reverse=True)
        buffer = candidates[:beam_width]

    return buffer

# ------------------------------------------------------------
# 6. Analysis: what sticks?
# ------------------------------------------------------------

def analyze(buffer):
    vertex_counts = defaultdict(int)
    for traj, _ in buffer:
        for v in traj:
            vertex_counts[v] += 1
    return vertex_counts

# ------------------------------------------------------------
# 7. Run the whole thing
# ------------------------------------------------------------

if __name__ == "__main__":
    print("Building synthetic 120-cell-like graph...")
    adjacency = build_symmetric_graph()

    print("Assigning memory and geometry labels...")
    M = assign_memory_labels(600)
    G = assign_geometry_labels(600)

    seed_vertex = 0
    print(f"Running simulation from seed vertex {seed_vertex}...")
    buffer = run_simulation(adjacency, M, G, seed=seed_vertex)

    print("Analyzing surviving trajectories...")
    counts = analyze(buffer)

    # Print top 10 most visited vertices
    top_vertices = sorted(counts.items(), key=lambda x: x[1], reverse=True)[:10]
    print("\nTop 10 most visited vertices:")
    for v, c in top_vertices:
        print(f"Vertex {v}: visited {c} times")

