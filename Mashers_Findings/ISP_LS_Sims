# -----------------------------
# 1. Define system
# -----------------------------

# Nodes: A=0, B=1, C=2
NODES = [0, 1, 2]

# All possible states (0 or 1 per node)
def random_state():
    return [random.choice([0, 1]) for _ in NODES]

# -----------------------------
# 2. Constraint function
# -----------------------------
# Constraints:
# (A,B): same
# (B,C): same
# (A,C): opposite

def constraint_energy(state):
    A, B, C = state

    violations = 0

    # A-B same
    if A != B:
        violations += 1

    # B-C same
    if B != C:
        violations += 1

    # A-C opposite
    if A == C:
        violations += 1

    return violations

# -----------------------------
# 3. Transition proposal
# -----------------------------
def propose_state(state):
    new_state = state.copy()
    i = random.choice(NODES)
    new_state[i] = 1 - new_state[i]  # flip bit
    return new_state

# -----------------------------
# 4. Transition rule (Metropolis-like)
# -----------------------------
def accept_probability(V_old, V_new, kappa=2.0):
    delta = V_new - V_old
    if delta <= 0:
        return 1.0
    else:
        return math.exp(-kappa * delta)

# -----------------------------
# 5. Simulation
# -----------------------------
def run_simulation(steps=1000, kappa=2.0):
    state = random_state()
    V = constraint_energy(state)

    history_V = []
    history_states = []

    for _ in range(steps):
        new_state = propose_state(state)
        V_new = constraint_energy(new_state)

        p = accept_probability(V, V_new, kappa)

        if random.random() < p:
            state = new_state
            V = V_new

        history_V.append(V)
        history_states.append(tuple(state))

    return history_V, history_states

# -----------------------------
# 6. Run it
# -----------------------------
steps = 2000
history_V, history_states = run_simulation(steps=steps, kappa=2.0)

# -----------------------------
# 7. Plot energy (Lyapunov)
# -----------------------------
plt.figure()
plt.plot(history_V)
plt.title("Lyapunov Functional V(R) Over Time")
plt.xlabel("Step")
plt.ylabel("V(R)")
plt.grid()
plt.show()

# -----------------------------
# 8. Analyze attractors
# -----------------------------
from collections import Counter

counts = Counter(history_states)

print("\nMost common states (attractors):")
for state, count in counts.most_common(5):
    print(f"{state} -> {count} visits")


