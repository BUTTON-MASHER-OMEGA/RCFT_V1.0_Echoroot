import random
import math
from collections import Counter

# ---------------------------------------------------------
# 1. Define the relational configuration
# ---------------------------------------------------------

# Nodes and their states
nodes = ["A", "B", "C"]

# Initial random state
def random_state():
    return {n: random.choice([0, 1]) for n in nodes}

# ---------------------------------------------------------
# 2. Constraint definitions (graded violations)
# ---------------------------------------------------------

def constraint_violation(R):
    """
    Compute V_constraint(R) for the frustrated triangle.
    Graded: 0 = satisfied, 1 = violated.
    """
    violations = 0

    # A-B prefer same
    violations += 1 if R["A"] != R["B"] else 0

    # B-C prefer same
    violations += 1 if R["B"] != R["C"] else 0

    # A-C prefer opposite
    violations += 1 if R["A"] == R["C"] else 0

    return violations  # integer 0–3


# ---------------------------------------------------------
# 3. Total Lyapunov functional V(R)
# ---------------------------------------------------------

def V(R):
    # For the first toy model, we only use constraint term
    return constraint_violation(R)


# ---------------------------------------------------------
# 4. Transition rule P(R' | R)
# ---------------------------------------------------------

def propose_new_state(R):
    """Flip one random node to propose R'."""
    R_new = R.copy()
    node = random.choice(nodes)
    R_new[node] = 1 - R_new[node]  # flip 0 ↔ 1
    return R_new

def accept(R, R_new, kappa=2.0):
    """
    Metropolis-like acceptance rule:
    Always accept if V decreases.
    Accept with probability exp(-kappa * ΔV) if V increases.
    """
    dV = V(R_new) - V(R)

    if dV <= 0:
        return True

    # Otherwise accept with Boltzmann probability
    p = math.exp(-kappa * dV)
    return random.random() < p


# ---------------------------------------------------------
# 5. Run the simulation
# ---------------------------------------------------------

def run_simulation(steps=2000):
    R = random_state()
    history = []
    visits = Counter()

    for t in range(steps):
        R_new = propose_new_state(R)

        if accept(R, R_new):
            R = R_new

        # Track history
        history.append(V(R))
        visits[tuple(R[n] for n in nodes)] += 1

    return history, visits


# ---------------------------------------------------------
# 6. Execute and display results
# ---------------------------------------------------------

history, visits = run_simulation(steps=5000)

print("State visitation counts:")
for state, count in visits.items():
    print(f"{state}: {count}")

print("\nFinal V:", history[-1])



