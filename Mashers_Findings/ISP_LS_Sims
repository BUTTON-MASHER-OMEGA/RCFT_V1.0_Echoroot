"""
RCFT Toy Universe 4.2 – Strict Minimal-Loss Version
No Metropolis-Hastings / no probabilistic uphill moves
Only downhill or flat transitions are accepted (ΔV ≤ 0)

This is closer to a pure indivisible stochastic process with strict coherence gradient preference.
"""

import random
import math
from statistics import mean

random.seed(42)


def get_neighbors(state):
    """1-flip admissible transitions (𝒩₁(R))"""
    neighbors = []
    for i in range(len(state)):
        neighbor = list(state)
        neighbor[i] = 1 - neighbor[i]
        neighbors.append(tuple(neighbor))
    return neighbors


def calc_v_base(state):
    """V_constraint + frustrated relational coupling"""
    G1, M1, G2, M2, G3, M3 = state
    v_cons = (G1 != M1) + (G2 != M2) + (G3 != M3)
    v_coup = (M1 != M2) + (M2 != M3) + (M3 == M1)
    return v_cons + v_coup


def calc_n_stable(state):
    """Proxy for basin width / refinement count"""
    base = calc_v_base(state)
    return sum(1 for n in get_neighbors(state) if calc_v_base(n) <= base)


def calc_v_total(state, alpha=1.0, beta=0.0, memory_penalty=0.0, mem_val=0):
    """Coherence free energy (Lyapunov functional)"""
    v_base = calc_v_base(state)
    n_stable = calc_n_stable(state)
    entropy = math.log(1 + n_stable) if n_stable > 0 else 0.0
    mem_term = memory_penalty * abs(mem_val)
    return alpha * v_base - beta * entropy + mem_term


def run_rcft_strict(steps=50000, alpha=1.0, beta=0.0, memory_penalty=0.0, label=""):
    """
    Strict indivisible dynamics:
    - Accept only if ΔV ≤ 0 (coherence non-decreasing)
    - No uphill moves allowed
    - Longer run (50k steps) to allow more time to reach attractors
    """
    current = tuple(random.randint(0, 1) for _ in range(6))
    vtotal_hist = []
    vbase_hist = []
    nstable_hist = []
    mem_val = 0
    accepted_moves = 0

    for t in range(steps):
        vtotal_hist.append(calc_v_total(current, alpha, beta, memory_penalty, mem_val))
        vbase_hist.append(calc_v_base(current))
        nstable_hist.append(calc_n_stable(current))

        proposed = random.choice(get_neighbors(current))

        dV = (calc_v_total(proposed, alpha, beta, memory_penalty, mem_val) -
              calc_v_total(current, alpha, beta, memory_penalty, mem_val))

        if dV <= 0:
            current = proposed
            accepted_moves += 1
            # Update memory proxy (symplectic flavor)
            mem_val = (mem_val + sum(current)) % 5

    final_vtotal = calc_v_total(current, alpha, beta, memory_penalty, mem_val)
    acceptance_rate = accepted_moves / steps if steps > 0 else 0

    print(f"\n=== {label}  |  β = {beta:.1f}  |  strict downhill only ===")
    print(f"Final attractor : {current}")
    print(f"  V_base           = {calc_v_base(current)}")
    print(f"  N_stable (basin) = {calc_n_stable(current)}")
    print(f"  V_total          = {final_vtotal:.3f}")
    print(f"Avg V_total over run: {mean(vtotal_hist):.3f}")
    print(f"Min V_total observed: {min(vtotal_hist):.3f}")
    print(f"Acceptance rate     : {acceptance_rate:.1%}  (only ΔV ≤ 0 moves)")
    print(f"Final memory val    : {mem_val}")

    # Show tail of trajectory
    tail_start = max(0, len(vtotal_hist) - 20)
    tail = vtotal_hist[tail_start:]
    print("\nLast 20 V_total values:")
    print(" ".join(f"{x:.3f}" for x in tail))

    print("→ Note: Without uphill moves the system may become trapped in local minima.\n")


# ────────────────────────────────────────────────
print("🚀 RCFT 4.2 Strict – No Metropolis-Hastings, Pure Minimal-Loss Kernel\n")

run_rcft_strict(beta=0.0,  label="1. Baseline (pure constraints)")
run_rcft_strict(beta=1.0,  label="2. Balanced Coherence (sweet spot)")
run_rcft_strict(beta=2.0,  label="3. Entropy-Dominated")
run_rcft_strict(beta=1.0, memory_penalty=0.25, label="4. Balanced + Light Memory Penalty")

print("\nDone. All runs use strict ΔV ≤ 0 acceptance only.")



